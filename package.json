{
  "name": "nowarelabs-bridge",
  "version": "1.0.5",
  "description": "Local terminal bridge for Nowarelabs editor",
  "main": "dist/index.js",
  "bin": {
    "nbb": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "postinstall": "node -e \"const fs=require('fs'),p=require('path'),dir=p.join(__dirname,'node_modules');function fix(d){try{const a=p.join(d,'spawn-helper'),b=p.join(d,'pty.node');fs.existsSync(a)&&fs.chmodSync(a,0o755);fs.existsSync(b)&&fs.chmodSync(b,0o755)}catch(e){}}['darwin-arm64','darwin-x64','win32-x64','win32-arm64'].forEach(x=>fix(p.join(dir,'node-pty','prebuilds',x)));console.log('Fixed node-pty permissions')\""
  },
  "dependencies": {
    "cli-boxes": "^3.0.0",
    "node-pty": "^1.0.0",
    "ws": "^8.14.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  }
}
